@model IEnumerable<eStudenti.Models.Studentet>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Index</h1>

<p>
    <a asp-action="Create" class="btn btn-outline-dark btn-sm">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Emri)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Mbiemri)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Gjinia)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Vendlindja)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Vendbanimi)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Shteti)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DataLindjes)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.NumriTelefonit)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Biografia)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Emri)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Mbiemri)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Gjinia)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Vendlindja)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Vendbanimi)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Shteti)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DataLindjes)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.NumriTelefonit)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Biografia)
            </td>
            <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Delete</a>
            </td>
        </tr>
     }
    </tbody>
</table>
