@model eStudenti.Models.Kurset

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Edit</h1>

<h4>Studentet</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="KursiId" />
            <div class="form-group">
                <label asp-for="EmriKursit" class="control-label"></label>
                <input asp-for="EmriKursit" class="form-control" />
                <span asp-validation-for="EmriKursit" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Ligjerusi" class="control-label"></label>
                <input asp-for="Ligjerusi" class="form-control" />
                <span asp-validation-for="Ligjerusi" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Kredit" class="control-label"></label>
                <input asp-for="Kredit" class="form-control" />
                <span asp-validation-for="Kredit" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Statusi" class="control-label"></label>
                <input asp-for="Statusi" class="form-check-input" type="checkbox" />
                <span asp-validation-for="Statusi" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-outline-dark btn-sm" />
                <a asp-action="Index" class="btn btn-outline-dark btn-sm">Back to List</a>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
